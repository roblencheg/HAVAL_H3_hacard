{
  "name": "lovelace-haval-h3-card",
  "version": "1.5.3",
  "description": "Lovelace custom card for Haval H3 dashboard with interactive vehicle overlays and map tracking",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/generate-default-image.mjs",
    "build": "rollup -c rollup.config.js",
    "watch": "rollup -c rollup.config.js --watch",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "check:version": "node scripts/check-version-sync.mjs",
    "test": "vitest run"
  },
  "license": "MIT",
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "haval",
    "haval-h3",
    "cesar-smart",
    "gwm",
    "hacs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/roblencheg/HAVAL_H3_hacard.git"
  },
  "bugs": {
    "url": "https://github.com/roblencheg/HAVAL_H3_hacard/issues"
  },
  "homepage": "https://github.com/roblencheg/HAVAL_H3_hacard#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "rollup": "^4.12.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "home-assistant-js-websocket": "^9.3.0",
    "lit": "^3.1.2"
  }
}
